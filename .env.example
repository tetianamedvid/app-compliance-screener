# No API keys. Trino uses SSO (browser opens for login on first use).
# To enable live Trino: set TRINO_HOST= or TRINO_DEFAULT_HOST= to your Trino host (e.g. trino.company.com).
# TRINO_DEFAULT_HOST can be set once in the repo so every user gets Trino + SSO when they open the app.
TRINO_HOST=
TRINO_DEFAULT_HOST=
TRINO_PORT=443
TRINO_CATALOG=prod
TRINO_USER=uw_app

# Use only local JSON (no Trino). Set to 1 when you don't have a working Trino host — app works immediately with the app list.
# TRINO_USE_LOCAL_ONLY=1

# Use your browser session so the app can run Trino like you: log into Quix in the browser, then copy the Cookie (or Authorization) from DevTools and paste here (one line, no line breaks). Restart the app.
# TRINO_COOKIE=session=abc123...
# TRINO_AUTH_HEADER=Bearer your-token

# Full data unlimited (local): path to a JSON file with full records (app_id, app_name, app_url, msid, account_id, conversation_summary, etc.). No limit on number of apps; each gets full profile.
# APPS_JSON_PATH=data/my_full_export.json

# Auto-refresh: path to a CSV/JSON that is the source of truth (e.g. where Quix or a cron drops the export). When set, the app re-imports from this file into APPS_JSON_PATH on open and at most once per hour. No dialogs.
# APPS_REFRESH_SOURCE_PATH=data/exports/latest_apps.csv
# APPS_REFRESH_EVERY_SECONDS=3600
